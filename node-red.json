    {
        "id": "b550d7e5a6152f05",
        "type": "function",
        "z": "8027da45117cac5a",
        "name": "Convert Controll Pintu",
        "func": "// Handle door/relay control from WebSocket\nconst data = msg.payload;\n\nif (!data.device || (data.device !== 'door' && data.device !== 'relay')) {\n    return [null, null, null, null, null, null, null, null];\n}\n\nconst room = data.room || 'livingroom';\nconst action = data.action || 'close';\n\n// Convert action to relay state\nconst relayPayload = action === 'open' ? 'on' : 'off';\n\n// Create message objects for each door output\nconst messages = [\n    null, // 0: livingroom\n    null, // 1: master_bedroom\n    null, // 2: kid_bedroom\n    null, // 3: servant_bedroom\n    null, // 4: terrace (back)\n    null, // 5: back\n    null, // 6: toilet1\n    null  // 7: toilet2\n];\n\nconst msg_payload = { payload: relayPayload };\n\n// Map room to output index\nif (room.toLowerCase().includes('living')) {\n    messages[0] = msg_payload;\n} else if (room.toLowerCase().includes('master')) {\n    messages[1] = msg_payload;\n} else if (room.toLowerCase().includes('kid')) {\n    messages[2] = msg_payload;\n} else if (room.toLowerCase().includes('servant')) {\n    messages[3] = msg_payload;\n} else if (room.toLowerCase().includes('terrace')) {\n    messages[4] = msg_payload;\n} else if (room.toLowerCase().includes('back')) {\n    messages[5] = msg_payload;\n} else if (room.toLowerCase().includes('toilet1')) {\n    messages[6] = msg_payload;\n} else if (room.toLowerCase().includes('toilet2')) {\n    messages[7] = msg_payload;\n}\n\nreturn messages;",
        "outputs": 8,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 540,
        "y": 380,
