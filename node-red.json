    {
        "id": "f810e3b439c1f863",
        "type": "function",
        "z": "8027da45117cac5a",
        "name": "Convert Controll AC",
        "func": "// Handle AC control from WebSocket\nconst data = msg.payload;\n\nif (!data.device || data.device !== 'ac') {\n    return [];\n}\n\nconst room = data.room || 'master';\nconst action = data.action || 'off';\nconst temp = data.temp || 24;\nconst mode = data.mode || 'cool';\nconst fan = data.fan || 'auto';\n\nconst payload = {\n    power: action === 'on' ? 'on' : 'off',\n    temp: temp,\n    mode: mode,\n    fan: fan\n};\n\nconst msg1 = { payload: JSON.stringify(payload) };  // servant_bedroom\nconst msg2 = { payload: JSON.stringify(payload) };  // kid_bedroom\nconst msg3 = { payload: JSON.stringify(payload) };  // master_bedroom\n\n// Route based on room parameter\nif (room.toLowerCase().includes('servant')) {\n    return [msg1, null, null];\n} else if (room.toLowerCase().includes('kid')) {\n    return [null, msg2, null];\n} else {\n    return [null, null, msg3];\n}\n\n// Or broadcast to all if room not specified clearly\nreturn [msg1, msg2, msg3];",
        "outputs": 3,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 400,
        "y": 260,
