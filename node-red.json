    {
        "id": "5603a285d3ae5248",
        "type": "function",
        "z": "8027da45117cac5a",
        "name": "Convert Sensor ",
        "func": "// Parse incoming MQTT sensor data from ESP32\nconst payload = msg.payload;\n\n// Pastikan nilai numerik (hindari string)\nconst temperature = parseFloat(payload.temperature) || 0.0;\nconst humidity = parseFloat(payload.humidity) || 0.0;\nconst lux = parseFloat(payload.lux) || 0;\n\n// --- Untuk InfluxDB (output ke-2) ---\n// Format yang sesuai dengan node-red-contrib-influxdb\nconst msgInflux = {\n    payload: {\n        measurement: \"smarthome\",          // Nama measurement\n        tags: {\n            device: \"esp32s3\"           // Tag untuk identifikasi\n        },\n        fields: {\n            temperature: temperature,\n            humidity: humidity,\n            lux: lux\n        }\n    }\n};\n\n// --- Untuk WebSocket / Frontend (output ke-1) ---\nconst wsMsg = {\n    payload: {\n        temperature: temperature,\n        humidity: humidity,\n        lux: lux,\n        limitSwitch: payload.limitSwitch || false\n    }\n};\n\n// Kembalikan dua output: [wsMsg, msgInflux]\nreturn [wsMsg, msgInflux];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 280,
        "y": 80,
        "wires": [
            [
                "c4a8ad397336201a"
            ],
