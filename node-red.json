    {
        "id": "3ee66c3509afda5d",
        "type": "function",
        "z": "8027da45117cac5a",
        "name": "Convert Controll Lamp",
        "func": "// Handle lamp and RGB control from WebSocket\nconst data = msg.payload;\n\nif (!data.device || (data.device !== 'lamp' && data.device !== 'rgb')) {\n    return [null, null, null, null, null, null, null, null];\n}\n\nconst room = data.room || 'livingroom';\n\n// Create message objects for each lamp output\nconst messages = [\n    null, // 0: master_bedroom\n    null, // 1: kid_bedroom\n    null, // 2: servant_bedroom\n    null, // 3: livingroom\n    null, // 4: kitchen\n    null, // 5: terrace\n    null, // 6: toilet1\n    null  // 7: toilet2\n];\n\nlet msg_payload;\n\nif (data.device === 'rgb') {\n    // RGB color control\n    msg_payload = {\n        payload: JSON.stringify({\n            r: data.r || 0,\n            g: data.g || 0,\n            b: data.b || 0\n        })\n    };\n} else {\n    // Simple on/off lamp control\n    const state = data.state === 'on' ? 'on' : 'off';\n    const brightness = data.brightness !== undefined ? data.brightness : 100;\n    \n    msg_payload = {\n        payload: JSON.stringify({\n            state: state,\n            brightness: brightness\n        })\n    };\n}\n\n// Map room to output index\nif (room.toLowerCase().includes('master')) {\n    messages[0] = msg_payload;\n} else if (room.toLowerCase().includes('kid')) {\n    messages[1] = msg_payload;\n} else if (room.toLowerCase().includes('servant')) {\n    messages[2] = msg_payload;\n} else if (room.toLowerCase().includes('living')) {\n    messages[3] = msg_payload;\n} else if (room.toLowerCase().includes('kitchen')) {\n    messages[4] = msg_payload;\n} else if (room.toLowerCase().includes('terrace')) {\n    messages[5] = msg_payload;\n} else if (room.toLowerCase().includes('toilet1')) {\n    messages[6] = msg_payload;\n} else if (room.toLowerCase().includes('toilet2')) {\n    messages[7] = msg_payload;\n}\n\nreturn messages;",
